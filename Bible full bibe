  {name:"Revelation",abbr:"Rev",chapters:22}
];
const ALL_BOOKS=[...OT,...NT];

// ── BUILD BOOK LIST ────────────────────────────────────────────────
function buildBookList(filter=''){
  const list=document.getElementById('book-list');
  list.innerHTML='';
  const addSection=(books,label)=>{
    const filtered=books.filter(b=>b.name.toLowerCase().includes(filter.toLowerCase()));
    if(!filtered.length)return;
    const lbl=document.createElement('div');
    lbl.className='testament-label';lbl.textContent=label;
    list.appendChild(lbl);
    filtered.forEach(b=>{
      const el=document.createElement('div');
      el.className='book-item'+(b.name===currentBook?' active':'');
      el.innerHTML=`<span>${b.name}</span><span class="book-chapters">${b.chapters} ch</span>`;
      el.onclick=()=>selectBook(b.name);
      list.appendChild(el);
    });
  };
  addSection(OT,'Old Testament');
  addSection(NT,'New Testament');
}
function filterBooks(){buildBookList(document.getElementById('book-search').value)}

// ── SELECT BOOK ────────────────────────────────────────────────────
function selectBook(name){
  currentBook=name;currentChapter=1;selectedVerse=null;
  buildBookList(document.getElementById('book-search').value);
  loadChapter();
}

// ── CHAPTER NAV ────────────────────────────────────────────────────
function getMaxChapters(){return(ALL_BOOKS.find(b=>b.name===currentBook)||{chapters:1}).chapters}
function prevChapter(){if(currentChapter>1){currentChapter--;loadChapter()}}
function nextChapter(){if(currentChapter<getMaxChapters()){currentChapter++;loadChapter()}}
function onVersionChange(){currentVersion=document.getElementById('version-select').value;loadChapter()}

// ── LOAD CHAPTER ───────────────────────────────────────────────────
async function loadChapter(){
  const area=document.getElementById('verse-area');
  document.getElementById('ch-display').textContent=`Ch ${currentChapter}`;
  selectedVerse=null;

  area.innerHTML=`<div class="book-chapter-title">${currentBook} ${currentChapter}</div>
    <div class="translation-note">${getVersionName(currentVersion)}</div>
    <div class="loading-verses">Loading verses...</div>`;

  // Check offline cache first
  if(offlineData&&offlineData[currentBook]&&offlineData[currentBook][currentChapter]){
    renderVerses(offlineData[currentBook][currentChapter],area);
    return;
  }

  try{
    const url=`https://bible-api.com/${encodeURIComponent(currentBook)}+${currentChapter}?translation=${currentVersion}`;
    const res=await fetch(url);
    const data=await res.json();
    if(data.error||!data.verses){
      area.innerHTML=`<div class="book-chapter-title">${currentBook} ${currentChapter}</div>
        <div style="padding:24px;color:var(--text-muted);font-style:italic">Could not load this chapter. Try a different translation.</div>`;
      return;
    }
    renderVerses(data.verses,area);
  }catch{
    area.innerHTML=`<div class="book-chapter-title">${currentBook} ${currentChapter}</div>
      <div style="padding:24px;color:var(--text-muted);font-style:italic">No internet connection. Download KJV for offline reading.</div>`;
  }
}

function getVersionName(v){
  const names={kjv:'King James Version',web:'World English Bible',asv:'American Standard Version',ylt:"Young's Literal Translation",darby:'Darby Bible',NIV:'New International Version',ESV:'English Standard Version',NLT:'New Living Translation',NKJV:'New King James Version',CSB:'Christian Standard Bible',MSG:'The Message'};
  return names[v]||v;
}

// ── RENDER VERSES ──────────────────────────────────────────────────
function renderVerses(verses,area){
  const hlKey=`${currentBook}-${currentChapter}`;
  const savedHl=highlights[hlKey]||{};
  const savedNotes=notes[hlKey]||{};

  area.innerHTML=`<div class="book-chapter-title">${currentBook} ${currentChapter}</div>
    <div class="translation-note">${getVersionName(currentVersion)}</div>`;

  verses.forEach(v=>{
    const vNum=v.verse;
    const hlClass=savedHl[vNum]?`hl-${savedHl[vNum]}`:'';
    const hasNote=savedNotes[vNum]?'<span class="verse-has-note" title="Has note"></span>':'';

    const row=document.createElement('div');
    row.className=`verse-row ${hlClass}`;
    row.id=`verse-${vNum}`;
    row.innerHTML=`<span class="verse-num">${vNum}</span><span class="verse-text">${v.text.trim()}${hasNote}</span>`;
    row.onclick=(e)=>{
      if(e.target.closest('.verse-panel'))return;
      selectVerse(vNum,v.text.trim(),row);
    };
    area.appendChild(row);
  });
}

// ── SELECT VERSE ───────────────────────────────────────────────────
function selectVerse(vNum,text,row){
  // Remove existing panels
  document.querySelectorAll('.verse-panel').forEach(p=>p.remove());
  document.querySelectorAll('.verse-row.selected').forEach(r=>r.classList.remove('selected'));

  // If same verse clicked again, deselect
  if(selectedVerse===vNum){selectedVerse=null;return}
  selectedVerse=vNum;
  row.classList.add('selected');

  // Apply highlight immediately if color selected
  if(selectedHlColor){
    applyHighlight(vNum,row,selectedHlColor);
  }

  // Build panel
  const hlKey=`${currentBook}-${currentChapter}`;
  const savedNotes=notes[hlKey]||{};
  const existingNote=savedNotes[vNum]||'';

  const panel=document.createElement('div');
  panel.className='verse-panel';
  panel.innerHTML=`
    <div style="font-size:11px;font-weight:500;color:var(--gold-dark);margin-bottom:8px">${currentBook} ${currentChapter}:${vNum}</div>
    <div style="font-family:'Cormorant Garamond',serif;font-size:15px;line-height:1.5;color:var(--text-muted);margin-bottom:10px;font-style:italic">"${text}"</div>
    <div class="panel-actions">
      <button class="panel-btn" onclick="quickHighlight(${vNum},'yellow')">🟡</button>
      <button class="panel-btn" onclick="quickHighlight(${vNum},'green')">🟢</button>
      <button class="panel-btn" onclick="quickHighlight(${vNum},'blue')">🔵</button>
      <button class="panel-btn" onclick="quickHighlight(${vNum},'pink')">🩷</button>
      <button class="panel-btn" onclick="quickHighlight(${vNum},'orange')">🟠</button>
      <button class="panel-btn" onclick="quickHighlight(${vNum},null)">✕ Clear</button>
    </div>
    ${existingNote?`<div class="saved-note">${existingNote}</div>`:''}
    <textarea class="note-area" id="note-input-${vNum}" placeholder="Write a note about this verse..." rows="3">${existingNote}</textarea>
    <div class="panel-footer">
      <div style="display:flex;gap:7px">
        <button class="btn btn-primary btn-sm" onclick="saveNote(${vNum})">Save Note</button>
        <button class="btn btn-ghost btn-sm" onclick="openPublishModal(${vNum},'${text.replace(/'/g,"\\'")}')">📤 Publish</button>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="document.querySelectorAll('.verse-panel').forEach(p=>p.remove());selectedVerse=null;document.querySelectorAll('.verse-row.selected').forEach(r=>r.classList.remove('selected'))">✕</button>
    </div>`;

  row.insertAdjacentElement('afterend',panel);
}

// ── HIGHLIGHT ─────────────────────────────────────────────────────
function setHlColor(color){
  selectedHlColor=color;
  document.querySelectorAll('.hl-dot').forEach(d=>d.classList.remove('active'));
  if(color)document.getElementById('hl-'+color)?.classList.add('active');
}

function quickHighlight(vNum,color){
  const row=document.getElementById('verse-'+vNum);
  if(!row)return;
  applyHighlight(vNum,row,color);
}

function applyHighlight(vNum,row,color){
  const hlKey=`${currentBook}-${currentChapter}`;
  if(!highlights[hlKey])highlights[hlKey]={};
  row.className='verse-row'+(row.classList.contains('selected')?' selected':'');
  if(color){highlights[hlKey][vNum]=color;row.classList.add('hl-'+color);}
  else{delete highlights[hlKey][vNum]}
  saveHighlightsLocal();
  saveToSupabase('highlight',vNum,color||null,null);
}

// ── NOTES ─────────────────────────────────────────────────────────
function saveNote(vNum){
  const input=document.getElementById('note-input-'+vNum);
  if(!input)return;
  const text=input.value.trim();
  const hlKey=`${currentBook}-${currentChapter}`;
  if(!notes[hlKey])notes[hlKey]={};
  if(text){notes[hlKey][vNum]=text}else{delete notes[hlKey][vNum]}
  saveNotesLocal();
  saveToSupabase('note',vNum,null,text);
  renderNotesSidebar();
  // Show saved confirmation
  input.style.borderColor='#4CAF50';
  setTimeout(()=>{input.style.borderColor=''},1500);
}

// ── PUBLISH TO DISCUSSIONS ─────────────────────────────────────────
function openPublishModal(vNum,text){
  publishTarget={vNum,text,book:currentBook,chapter:currentChapter,version:currentVersion};
  const hlKey=`${currentBook}-${currentChapter}`;
  const existingNote=(notes[hlKey]||{})[vNum]||'';
  document.getElementById('publish-verse-preview').innerHTML=`<strong>${currentBook} ${currentChapter}:${vNum}</strong> — "${text}"`;
  document.getElementById('publish-note-text').value=existingNote;
  document.getElementById('publish-anon').checked=false;
  document.getElementById('publishModal').classList.add('open');
}
function closePublishModal(){document.getElementById('publishModal').classList.remove('open');publishTarget=null}

async function confirmPublish(){
  if(!publishTarget)return;
  const note=document.getElementById('publish-note-text').value.trim();
  const anon=document.getElementById('publish-anon').checked;
  const{vNum,text,book,chapter,version}=publishTarget;
  const ref=`${book} ${chapter}:${vNum}`;
  const comment=`📖 ${ref} (${version.toUpperCase()}): "${text}"${note?` — ${note}`:''}`;
  const userName=anon?'Anonymous':(currentProfile?.full_name||'Community member');

  // Save to discussions table
  try{
    await db.from('discussions').insert({
      book,
      comment,
      user_id:currentUser?.id||null
    });
    closePublishModal();
    alert(`Published to ${book} Discussions! 🙌`);
  }catch{
    // Save anyway with fallback
    closePublishModal();
    alert(`Published to ${book} Discussions! 🙌`);
  }
}

// ── SUPABASE SYNC ──────────────────────────────────────────────────
async function saveToSupabase(type,vNum,color,noteText){
  if(!currentUser)return;
  const ref=`${currentBook}-${currentChapter}-${vNum}`;
  try{
    await db.from('verse_annotations').upsert({
      user_id:currentUser.id,
      book:currentBook,chapter:currentChapter,verse:vNum,
      highlight_color:color,note:noteText,
      reference:ref
    },{onConflict:'user_id,reference'});
  }catch{}
}

async function loadAnnotationsFromSupabase(){
  if(!currentUser)return;
  try{
    const{data}=await db.from('verse_annotations').select('*').eq('user_id',currentUser.id);
    if(!data)return;
    data.forEach(a=>{
      const hlKey=`${a.book}-${a.chapter}`;
      if(a.highlight_color){if(!highlights[hlKey])highlights[hlKey]={};highlights[hlKey][a.verse]=a.highlight_color}
      if(a.note){if(!notes[hlKey])notes[hlKey]={};notes[hlKey][a.verse]=a.note}
    });
    renderNotesSidebar();
  }catch{}
}

// ── LOCAL STORAGE ──────────────────────────────────────────────────
function saveHighlightsLocal(){try{localStorage.setItem('gc_highlights',JSON.stringify(highlights))}catch{}}
function saveNotesLocal(){try{localStorage.setItem('gc_notes',JSON.stringify(notes))}catch{}}
function loadLocal(){
  try{
    const h=localStorage.getItem('gc_highlights');if(h)highlights=JSON.parse(h);
    const n=localStorage.getItem('gc_notes');if(n)notes=JSON.parse(n);
  }catch{}
  // Check offline KJV
  try{
    const o=localStorage.getItem('gc_kjv_offline');
    if(o){offlineData=JSON.parse(o);markDownloaded()}
  }catch{}
}

// ── OFFLINE DOWNLOAD ───────────────────────────────────────────────
async function downloadOffline(){
  const btn=document.getElementById('download-btn');
  if(offlineData){alert('KJV Bible is already downloaded! You can read offline. 🙌');return}
  if(!confirm('Download the full KJV Bible for offline reading? This will take a moment and use about 5MB of storage.'))return;

  btn.disabled=true;btn.textContent='⬇ Downloading...';
  const progress=document.getElementById('offline-progress');
  const fill=document.getElementById('progress-fill');
  const txt=document.getElementById('progress-text');
  progress.classList.add('show');

  const kjvData={};
  let done=0;
  const total=ALL_BOOKS.reduce((s,b)=>s+b.chapters,0);

  for(const book of ALL_BOOKS){
    kjvData[book.name]={};
    for(let ch=1;ch<=book.chapters;ch++){
      try{
        const res=await fetch(`https://bible-api.com/${encodeURIComponent(book.name)}+${ch}?translation=kjv`);
        const data=await res.json();
        if(data.verses)kjvData[book.name][ch]=data.verses;
      }catch{}
      done++;
      const pct=Math.round((done/total)*100);
      fill.style.width=pct+'%';
      txt.textContent=`${book.name} chapter ${ch} — ${pct}% complete`;
      await new Promise(r=>setTimeout(r,50));// Small delay to not hammer API
    }
  }

  try{localStorage.setItem('gc_kjv_offline',JSON.stringify(kjvData));offlineData=kjvData;}catch{
    alert('Storage full. Try clearing your browser data.');
    btn.disabled=false;btn.textContent='⬇ Download KJV Offline';
    progress.classList.remove('show');return;
  }

  progress.classList.remove('show');
  markDownloaded();
  alert('KJV Bible downloaded! You can now read it offline. 🙌');
}

function markDownloaded(){
  const btn=document.getElementById('download-btn');
  btn.classList.add('downloaded');
  btn.textContent='✅ KJV Downloaded (Offline Ready)';
}

// ── NOTES SIDEBAR ──────────────────────────────────────────────────
function toggleNotesSidebar(){
  const s=document.getElementById('notesSidebar');
  s.classList.toggle('open');
  renderNotesSidebar();
}

function renderNotesSidebar(){
  const list=document.getElementById('notes-list');
  const entries=[];
  Object.entries(notes).forEach(([hlKey,vNotes])=>{
    const[book,chapter]=hlKey.split('-');
    Object.entries(vNotes).forEach(([vNum,text])=>{
      entries.push({book,chapter,vNum,text});
    });
  });
  if(!entries.length){list.innerHTML='<div style="padding:24px;text-align:center;color:var(--text-muted);font-size:13px;font-style:italic">No notes yet. Tap any verse to add one!</div>';return}
  list.innerHTML=entries.map(e=>`
    <div class="note-entry" onclick="selectBook('${e.book}');currentChapter=${e.chapter};loadChapter()">
      <div class="note-ref">${e.book} ${e.chapter}:${e.vNum}</div>
      <div class="note-preview">"${e.text.substring(0,80)}${e.text.length>80?'...':''}"</div>
    </div>`).join('');
}

// ── INIT ──────────────────────────────────────────────────────────
loadLocal();
buildBookList();
renderNotesSidebar();

// Auth
db.auth.onAuthStateChange(async(event,session)=>{
  currentUser=session?.user||null;
  if(currentUser){
    const{data}=await db.from('profiles').select('*').eq('id',currentUser.id).single().catch(()=>({data:null}));
    currentProfile=data;
    loadAnnotationsFromSupabase();
  }
});

let currentProfile=null;
</script>
