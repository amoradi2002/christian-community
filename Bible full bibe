  {name:"Philemon",abbr:"Phlm",chapters:1},{name:"Hebrews",abbr:"Heb",chapters:13},{name:"James",abbr:"Jas",chapters:5},
  {name:"1 Peter",abbr:"1Pet",chapters:5},{name:"2 Peter",abbr:"2Pet",chapters:3},{name:"1 John",abbr:"1John",chapters:5},
